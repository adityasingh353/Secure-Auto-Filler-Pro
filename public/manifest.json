{
  "manifest_version": 3,
  "name": "Secure Auto-Filler Pro",
  "version": "1.0.0",
  "description": "Intelligently fill online examination and registration forms with secure, locally-stored personal data and documents.",
  "permissions": [
    "storage",
    "webRequest",
    "tabs",
    "scripting",
    "activeTab",
    "offscreen",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "Secure Auto-Filler Panel"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
